{
  "name": "aigcroom",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "npx ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }) } catch (e) {}\"",
    "build:clean": "npm run clean && npm run build",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@swc/helpers": "0.5.12",
