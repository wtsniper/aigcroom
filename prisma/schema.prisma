generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 模块 1: 用户系统
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // bcrypt 加密
  image         String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  subscriptions Subscription?
  reviews       Review[]
  comments      Comment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==========================================
// 模块 2: 工具系统
// ==========================================
model Tool {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String
  logoUrl         String
  websiteUrl      String
  affiliateUrl    String?
  category        String
  rating          Float         @default(0)
  ratingFeatures  Float         @default(0)
  ratingEase      Float         @default(0)
  ratingValue     Float         @default(0)
  ratingSupport   Float         @default(0)
  pricingType     String @default("FREE")
  priceMonthly    Float?
  priceYearly     Float?
  tags            String?       // JSON array as string
  pros            String?       // JSON array as string
  cons            String?       // JSON array as string
  isFeatured      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // 关联
  favorites       Favorite[]
  pricingPlans    PricingPlan[]
  reviews         Review[]
  affiliateLinks  AffiliateLink[]
  comments        Comment[]

  @@map("tools")
}

model PricingPlan {
  id            String   @id @default(cuid())
  toolId        String
  name          String
  description   String?
  priceMonthly  Float?
  priceYearly   Float?
  features      String?  // JSON array as string
  affiliateUrl  String?
  isPopular     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tool          Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@map("pricing_plans")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@map("favorites")
}

// ==========================================
// 模块 3: 内容系统（评测文章）
// ==========================================
model Review {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    // Markdown 或 HTML
  toolId      String?
  authorId    String
  status      String @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tool        Tool?     @relation(fields: [toolId], references: [id], onDelete: SetNull)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@map("reviews")
}

// ==========================================
// 模块 4: 行业解决方案
// ==========================================
model Solution {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  industry     String
  icon         String
  content      String?
  toolIds      String?  // JSON array as string
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("solutions")
}

// ==========================================
// 模块 5: 支付订阅系统
// ==========================================
model Subscription {
  id              String              @id @default(cuid())
  userId          String              @unique
  planType        String              @default("FREE")
  status          String              @default("ACTIVE")
  stripeCustomerId    String?
  stripeSubscriptionId String?
  priceId         String?
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ==========================================
// 模块 6: 联盟链接追踪系统
// ==========================================
model AffiliateLink {
  id            String   @id @default(cuid())
  toolId        String?
  url           String
  slug          String   @unique
  platform      String?
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  revenue       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tool          Tool?    @relation(fields: [toolId], references: [id], onDelete: SetNull)
  affiliateClicks AffiliateClick[]

  @@map("affiliate_links")
}

model AffiliateClick {
  id               String   @id @default(cuid())
  linkId           String
  ipAddress        String?
  userAgent        String?
  referralSource   String?
  converted        Boolean  @default(false)
  conversionAmount Float?
  clickedAt        DateTime @default(now())

  link             AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("affiliate_clicks")
}

// ==========================================
// 模块 7: 对比历史
// ==========================================
model Comparison {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  toolIds   String?  // JSON array as string
  content   String?
  conclusion String?
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comparisons")
}

// ==========================================
// 模块 8: 邮箱验证码
// ==========================================
model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("REGISTER")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("email_verifications")
}

// ==========================================
// 模块 9: 评论系统
// ==========================================
model Comment {
  id        String    @id @default(cuid())
  content   String
  userId    String
  toolId    String?
  reviewId  String?
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      Tool?     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  review    Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([toolId])
  @@index([reviewId])
  @@map("comments")
}