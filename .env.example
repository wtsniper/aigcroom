# ==========================================
# Next.js & NextAuth
# ==========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# 数据库（Prisma schema 为 postgresql；不要用 SQLite file: URL）
# Neon 连接串若含 channel_binding=require，在 Node/pg 下可能连不上，可去掉该参数。
# ==========================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# ==========================================
# Google OAuth (登录)
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# GitHub OAuth (登录)
# ==========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==========================================
# Stripe 支付
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx
# 定价页 ENTERPRISE 档使用 STRIPE_PRICE_PREMIUM（或另设 STRIPE_PRICE_ENTERPRISE）
# Webhook URL（生产）: https://你的域名/api/stripe/webhook

# ==========================================
# 管理员邮箱（第一个注册的这个邮箱会变成管理员）
# ==========================================
ADMIN_EMAIL=admin@yourdomain.com

# ==========================================
# 邮件发送 (SMTP) — 用于发送注册验证码
# 推荐使用 QQ 邮箱 / 163 邮箱 / Gmail / SendGrid / Resend 等 SMTP 服务
# QQ 邮箱: host=smtp.qq.com  port=587  user=xxxx@qq.com  pass=<授权码(非密码)>
# 163邮箱: host=smtp.163.com port=465  user=xxxx@163.com pass=<授权码>
# Gmail:   host=smtp.gmail.com port=587 user=xxxx@gmail.com pass=<App Password>
# ==========================================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
EMAIL_FROM_NAME=AIGCRoom
